<%- include('../partials/head') %>
<%- include('../partials/navbar') %>

<!-- HERO SECTION -->
<section id="hero" class="hero">
  <div class="hero-bg-grid"></div>

  <div class="hero-left fade-up">
    <div class="hero-available">
      <span class="hero-available-dot"></span>
      Available for roles &amp; internships
    </div>

    <h1 class="hero-name">
      Hi, I'm<br><em>Aywinner.</em>
    </h1>
    <p class="hero-title">Backend Software Engineer</p>
    <p class="hero-desc">
      I build clean, scalable REST APIs with Node.js and Express.
      Based in Lagos, Nigeria — open to remote and hybrid opportunities worldwide.
    </p>

    <div class="hero-actions">
      <a href="/projects" class="btn-primary">View my work →</a>
      <a href="/contact"  class="btn-secondary">Get in touch</a>
      <a href="https://github.com/Sola-ayomide" class="btn-ghost" target="_blank" rel="noopener">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.418 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.009-.868-.013-1.703-2.782.604-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.463-1.11-1.463-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836a9.59 9.59 0 012.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.163 22 16.418 22 12c0-5.523-4.477-10-10-10z"/></svg>
        GitHub
      </a>
    </div>

    <div class="hero-stats">
      <div class="hero-stat">
        <div class="hero-stat-num">3+</div>
        <div class="hero-stat-label">Projects shipped</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-num">2</div>
        <div class="hero-stat-label">Programmes completed</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat-num">★</div>
        <div class="hero-stat-label">Graduated with Distinction</div>
      </div>
    </div>
  </div>

  <div class="hero-right fade-up fade-delay">
    <div class="hero-card">
      <span class="floating-badge">OPEN TO WORK</span>
      <div class="hero-card-top">
        <div class="hero-avatar hero-avatar-img">
        <img src="/images/Aywinner.jpg" alt="Aywinner" />
        </div>
        <div>
          <div class="hero-card-name">Aywinner</div>
          <div class="hero-card-role">Backend Engineer · Lagos, NG</div>
        </div>
      </div>
      <div class="hero-card-divider"></div>
      <div class="hero-card-row">Location <span>Lagos, Nigeria 🇳🇬</span></div>
      <div class="hero-card-row">Experience <span>Backend Engineering</span></div>
      <div class="hero-card-row">Education <span>B.Eng + TechCrush '26</span></div>
      <div class="hero-card-row">Email <span>aywinner.dev@gmail.com</span></div>
      <div class="hero-card-divider"></div>
      <div class="hero-card-stack-label">Core stack</div>
      <div class="hero-card-stack">
        <span class="tag tag-green">Node.js</span>
        <span class="tag tag-green">Express.js</span>
        <span class="tag tag-green">MongoDB</span>
        <span class="tag">JWT</span>
        <span class="tag">REST APIs</span>
        <span class="tag">Mongoose</span>
      </div>
    </div>
  </div>
</section>

<!-- ABOUT SECTION -->
<section id="about" class="section section-alt">
  <div class="section-inner">
    <p class="section-tag">About me</p>
    <div class="about-grid">

  <!-- Photo column -->
  <div class="about-photo-wrap fade-up">
    <div class="about-photo-card">
      <img src="/images/Aywinner.jpg" alt="Aywinner" class="about-photo" />
      <div class="about-photo-badge">
        <span class="hero-available-dot"></span>
        Open to work
      </div>
    </div>
  </div>

  <!-- Text column -->
  <div class="fade-up fade-delay">
    <h2 class="section-heading">Building things that<br>work behind the scenes.</h2>
        <p class="body-text">
          I'm a backend engineer based in Lagos, passionate about building clean, reliable server-side systems.
          I specialise in Node.js and Express — designing RESTful APIs, handling authentication, and wiring up
          databases with Mongoose.
        </p>
        <p class="body-text">
          Before software, I studied Civil Engineering at FUOYE — which gave me a strong foundation in structured
          thinking, systems design, and solving complex problems with constraints. I bring that same mindset to code.
        </p>
        <blockquote class="about-quote">
          "Graduated with Distinction from TechCrush's Backend Engineering Programme, 2026."
        </blockquote>
        <div class="btn-row">
          <a href="/contact" class="btn-primary">Work with me</a>
          <a href="/api/resume" class="btn-secondary">Download CV</a>
        </div>
      </div>

      <div class="skills-grid fade-up fade-delay">
        <div class="skill-card">
          <div class="skill-icon">⚙️</div>
          <div class="skill-label">Runtime &amp; Framework</div>
          <div class="skill-tags"><span class="tag">Node.js</span><span class="tag">Express.js</span></div>
        </div>
        <div class="skill-card">
          <div class="skill-icon">🗄️</div>
          <div class="skill-label">Database</div>
          <div class="skill-tags"><span class="tag">MongoDB</span><span class="tag">Mongoose</span></div>
        </div>
        <div class="skill-card">
          <div class="skill-icon">🔐</div>
          <div class="skill-label">Auth &amp; Security</div>
          <div class="skill-tags"><span class="tag">JWT</span><span class="tag">bcryptjs</span></div>
        </div>
        <div class="skill-card">
          <div class="skill-icon">📦</div>
          <div class="skill-label">Tools &amp; Libraries</div>
          <div class="skill-tags"><span class="tag">Nodemailer</span><span class="tag">Multer</span><span class="tag">Swagger</span></div>
        </div>
        <div class="skill-card">
          <div class="skill-icon">🌐</div>
          <div class="skill-label">Views &amp; Frontend</div>
          <div class="skill-tags"><span class="tag">EJS</span><span class="tag">Vanilla JS</span><span class="tag">CSS</span></div>
        </div>
        <div class="skill-card">
          <div class="skill-icon">🛠️</div>
          <div class="skill-label">Dev Tools</div>
          <div class="skill-tags"><span class="tag">Git</span><span class="tag">GitHub</span><span class="tag">Postman</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FEATURED PROJECTS -->
<section class="section">
  <div class="section-inner">
    <div class="section-header fade-up">
      <div>
        <p class="section-tag">Projects</p>
        <h2 class="section-heading" style="margin-bottom:0">Things I've built.</h2>
      </div>
      <a href="/projects" class="btn-ghost">All projects →</a>
    </div>

    <div class="projects-grid">
      <% projects.forEach((p, i) => { %>
      <div class="project-card <%= p.featured ? 'featured' : '' %> fade-up" style="--delay:<%=i*80%>ms">
        <div class="project-thumb <%= p.thumbClass %>">
          <div class="project-thumb-pattern"></div>
          <div class="project-thumb-label">
            <span class="project-thumb-name"><%= p.name %></span>
            <span class="project-thumb-sub"><%= p.type.toUpperCase() %></span>
          </div>
        </div>
        <div class="project-body">
          <div class="project-badges">
            <span class="project-badge <%= p.badgeClass %>"><%= p.type %></span>
          </div>
          <h3 class="project-title"><%= p.name %></h3>
          <p class="project-desc"><%= p.description.substring(0, 120) %>...</p>
          <div class="project-stack">
            <% p.techStack.slice(0,5).forEach(t => { %><span class="tag"><%= t %></span><% }) %>
          </div>
          <div class="project-links">
            <% if (p.github) { %>
            <a href="<%= p.github %>" class="project-link gh" target="_blank" rel="noopener">GitHub →</a>
            <% } %>
            <% if (p.live) { %>
            <a href="<%= p.live %>" class="project-link live" target="_blank" rel="noopener">Live demo ↗</a>
            <% } %>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</section>

<!-- API PLAYGROUND -->
<section id="playground" class="section">
  <div class="section-inner">
    <div class="playground-wrap fade-up">
      <div class="playground-bg"></div>
      <div class="playground-inner">
        <p class="playground-tag">Live API playground</p>
        <h2 class="playground-title">Hit my actual APIs.</h2>
        <p class="playground-sub">Real endpoints — click to fire a live request and see the JSON response.</p>

        <div class="playground-grid">
          <div class="endpoint-card">
            <span class="endpoint-method method-get">GET</span>
            <div class="endpoint-path">/api/randomjoke</div>
            <div class="endpoint-desc">Returns a random joke from the collection.</div>
            <button class="endpoint-btn" data-url="/api/randomjoke" data-target="r1">Run request →</button>
            <pre class="response-box" id="r1"></pre>
          </div>
          <div class="endpoint-card">
            <span class="endpoint-method method-get">GET</span>
            <div class="endpoint-path">/api/randomjoke?type=short</div>
            <div class="endpoint-desc">Returns only short jokes (under 30 words).</div>
            <button class="endpoint-btn" data-url="/api/randomjoke?type=short" data-target="r2">Run request →</button>
            <pre class="response-box" id="r2"></pre>
          </div>
          <div class="endpoint-card">
            <span class="endpoint-method method-get">GET</span>
            <div class="endpoint-path">/api/projects</div>
            <div class="endpoint-desc">Returns all portfolio projects as JSON.</div>
            <button class="endpoint-btn" data-url="/api/projects" data-target="r3">Run request →</button>
            <pre class="response-box" id="r3"></pre>
          </div>
          <div class="endpoint-card">
            <span class="endpoint-method method-get">GET</span>
            <div class="endpoint-path">/api/blog</div>
            <div class="endpoint-desc">Returns all published blog posts.</div>
            <button class="endpoint-btn" data-url="/api/blog" data-target="r4">Run request →</button>
            <pre class="response-box" id="r4"></pre>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- RECENT BLOG -->
<% if (recentPosts.length > 0) { %>
<section class="section section-alt">
  <div class="section-inner">
    <div class="section-header fade-up">
      <div>
        <p class="section-tag">Blog / Devlog</p>
        <h2 class="section-heading" style="margin-bottom:0">Writing &amp; learnings.</h2>
      </div>
      <a href="/blog" class="btn-ghost">All posts →</a>
    </div>
    <div class="blog-grid">
      <% recentPosts.forEach((post, i) => { %>
      <a href="/blog/<%= post.slug %>" class="blog-card fade-up" style="--delay:<%=i*80%>ms">
        <div class="blog-date">
          <%= post.createdAt.toLocaleDateString('en-US', {month:'short', year:'numeric'}).toUpperCase() %>
          · <%= post.readTime %> MIN READ
        </div>
        <h3 class="blog-title"><%= post.title %></h3>
        <p class="blog-excerpt"><%= post.excerpt %></p>
        <span class="blog-read-more">Read more →</span>
      </a>
      <% }) %>
    </div>
  </div>
</section>
<% } %>

<%- include('../partials/footer') %>
